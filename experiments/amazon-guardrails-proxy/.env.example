# OpenAI API key for Realtime API access
OPENAI_API_KEY=sk-your-key-here

# Server config
HOST=0.0.0.0
PORT=8000

# AWS Bedrock Guardrails
# Create a Guardrail in the AWS Bedrock console, then paste the ID here.
# Steps: AWS Console → Bedrock → Guardrails → Create guardrail
# Enable: Content filters (prompt attack = HIGH), Sensitive info filters (PII = ANONYMIZE)
GUARDRAIL_ID=your-guardrail-id-here
GUARDRAIL_VERSION=DRAFT
AWS_REGION=us-east-1
# AWS_PROFILE=cb-genai-nonprod-dev-cli

# AWS credentials (if not using IAM role / instance profile / SSO)
# Typically set via `aws configure` or environment, not here.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

# Logging level (DEBUG shows redacted values — never use in prod)
LOG_LEVEL=INFO

# Dry-run mode: process messages but don't forward to OpenAI
# Set to true for testing without an OpenAI key
# DRY_RUN=true
